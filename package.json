{
  "name": "skillx",
  "private": true,
  "packageManager": "npm@10.8.2",
  "description": "SkillX - AI-powered skill barter and mentorship platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npx turbo build",
    "build:api": "npx turbo build --filter=@skillx/api",
    "db:generate": "npx turbo db:generate",
    "postinstall": "npm run db:generate",
    "dev": "npx turbo dev",
    "lint": "npx turbo lint",
    "test": "npx turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}