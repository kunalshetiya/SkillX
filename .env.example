# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:password@localhost:5433/skillx?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=skillx

# --- Backend (@skillx/api) ---
PORT=4000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# --- Frontend (@skillx/web) ---
NEXT_PUBLIC_APP_NAME=SkillX
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# --- Future Optional Infrastructure ---
REDIS_URL=
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
