# --- Database (Neon / PostgreSQL) ---
# Neon connection string (pooled or direct)
DATABASE_URL=postgresql://postgres:password@localhost:5433/skillx?schema=public
# Use a direct URL for Prisma migrations if using a pooler (like PgBouncer)
DIRECT_URL=

# --- Backend (@skillx/api) ---
PORT=4000
NODE_ENV=production
# Frontend URL for CORS (e.g., https://skillx.vercel.app)
FRONTEND_URL=http://localhost:3000

# --- Clerk Authentication ---
# Frontend Public Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/profile
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/profile

# Backend Secret Key
CLERK_SECRET_KEY=

# --- Frontend (@skillx/web) ---
NEXT_PUBLIC_APP_NAME=SkillX
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
