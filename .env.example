# --- Database (Neon / PostgreSQL) ---
# Neon connection string (pooled or direct)
DATABASE_URL="postgresql://user:password@ep-shard-name.aws.neon.tech/neondb?sslmode=require"
# Use a direct URL for Prisma migrations if using a pooler (like PgBouncer)
DIRECT_URL="postgresql://user:password@ep-shard-name.aws.neon.tech/neondb?sslmode=require"

# --- Backend (@skillx/api) ---
PORT=4000
NODE_ENV=production
# Frontend URL for CORS (e.g., https://skillx.vercel.app)
FRONTEND_URL=https://skillx.vercel.app

# --- Clerk Authentication ---
# Frontend Public Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/profile
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/profile

# Backend Secret Key
CLERK_SECRET_KEY=sk_test_...

# --- Frontend (@skillx/web) ---
NEXT_PUBLIC_APP_NAME=SkillX
# Deployed Backend URL
NEXT_PUBLIC_API_URL=https://skillx-mod4.onrender.com/api/v1
